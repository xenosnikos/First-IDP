# ──────────────────────────────────────────────
# TWIZZ-IDP Dashboard - Environment Variables
# Copy to .env.local and fill in all values
# ──────────────────────────────────────────────

# ── Database (RDS PostgreSQL) ─────────────────
DATABASE_URL=postgresql://twizz_admin:PASSWORD@rds-endpoint.eu-west-1.rds.amazonaws.com:5432/twizz_idp

# ── NextAuth (GitHub OAuth) ───────────────────
# Create GitHub OAuth App: https://github.com/organizations/Twizz/settings/applications/new
# Homepage URL: https://idp.twizz.app (or http://localhost:3000 for local)
# Callback URL: https://idp.twizz.app/api/auth/callback/github
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # Generate: openssl rand -base64 32
GITHUB_CLIENT_ID=  # From GitHub OAuth App settings
GITHUB_CLIENT_SECRET=  # From GitHub OAuth App settings
GITHUB_ORG=Twizz  # GitHub organization name for repo listing

# ── AWS (Secrets Manager, ECR) ────────────────
# For local dev use AWS CLI profile. For ECS, use task role (no keys needed).
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=  # Only for local dev
AWS_SECRET_ACCESS_KEY=  # Only for local dev

# ── Argo Workflows ───────────────────────────
# Local: kubectl port-forward -n argo svc/argo-workflows-server 2746:2746
ARGO_WORKFLOWS_URL=http://localhost:2746
ARGO_TOKEN=  # kubectl -n argo create token argo-workflows-server

# ── Argo CD ──────────────────────────────────
# Local: kubectl port-forward -n argocd svc/argocd-server 8080:443
ARGO_CD_URL=http://localhost:8080
ARGOCD_AUTH_TOKEN=  # argocd account generate-token --account admin

# ── Vercel (Frontend Deploys) ────────────────
# Create token: https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_TEAM_ID=team_eZiKDLZPnCBSKY38QPwbje5G

# ── MongoDB Atlas (Database Provisioning) ────
# Atlas -> Organization -> Access Manager -> API Keys
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
ATLAS_PROJECT_ID=

# ── Anthropic (Claude API) ──────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
